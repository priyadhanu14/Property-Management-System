# Supabase Postgres (async). Get from Supabase Dashboard -> Project Settings -> Database.
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: Supabase Auth (JWT validation for API)
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
